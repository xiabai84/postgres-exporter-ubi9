pipeline {
    agent { label 'cing-go' }

    environment {
        APP              = 'postgres-exporter'
        NEXUS_URL        = 'https://nexus.internal'
        NEXUS_REPOSITORY = 'internet-go-proxy.golang.org-proxy'
        VERSION          = '0.19.1'
        GOPROXY          = "${NEXUS_URL}/repository/${NEXUS_REPOSITORY}/"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            steps {
                withCredentials([usernamePassword(
                    credentialsId: 'nexus-credentials',
                    usernameVariable: 'NEXUS_USER',
                    passwordVariable: 'NEXUS_PASS'
                )]) {
                    sh '''
                        NETRC_FILE=$(mktemp)
                        trap "rm -f ${NETRC_FILE}" EXIT

                        cat > "${NETRC_FILE}" <<EOF
machine nexus.internal
login ${NEXUS_USER}
password ${NEXUS_PASS}
EOF
                        export GONETRC="${NETRC_FILE}"
                        export GOPROXY="${GOPROXY}"

                        cd src
                        CGO_ENABLED=0 GOOS=linux GOARCH=amd64 \
                            go build \
                                -trimpath \
                                -ldflags="-s -w \
                                    -X github.com/prometheus/common/version.Version=${VERSION} \
                                    -X github.com/prometheus/common/version.Branch=release \
                                    -X github.com/prometheus/common/version.BuildUser=jenkins \
                                    -X github.com/prometheus/common/version.BuildDate=$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
                                -o ../postgres_exporter \
                                ./cmd/postgres_exporter

                        ../postgres_exporter --version
                    '''
                }
            }
        }

        stage('Build Image') {
            steps {
                // TODO: Replace with your shared library call, e.g.:
                // buildDockerImage(
                //     app: APP,
                //     version: VERSION,
                //     artifact: 'postgres_exporter',
                //     dockerfile: 'single-stage/Dockerfile',
                // )
                echo "Build image skipped — integrate your shared library here"
            }
        }

        stage('Push Image') {
            steps {
                // TODO: Replace with your shared library call, e.g.:
                // pushDockerImage(
                //     app: APP,
                //     version: VERSION,
                //     registry: 'registry.internal',
                // )
                echo "Push skipped — integrate your shared library here"
            }
        }
    }

    post {
        success {
            echo "Build successful: ${APP} v${VERSION}"
        }
        failure {
            echo "Build failed — check stage logs for details"
        }
        always {
            sh 'rm -f postgres_exporter'
        }
    }
}
